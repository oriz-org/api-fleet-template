---
import Layout from '../layouts/Layout.astro';
import fleetConfig from 'virtual:oriz-fleet-config';

const {
  apiName,
  apiTitle,
  githubRepo,
  dataDirs,
  indexFiles,
  endpoints,
  sampleResponse,
  licenseBlurb,
} = fleetConfig;

const siteHost = `${apiName}.oriz.in`;
const jsdelivrBase = `https://cdn.jsdelivr.net/gh/${githubRepo}@main`;

// Derive a default endpoint table if the consumer didn't pass one.
function defaultEndpoints() {
  const rows: Array<{ path: string; returns: string; sample: string }> = [];
  for (const dir of dataDirs || []) {
    rows.push({
      path: `/${dir}/<SLUG>.json`,
      returns: `One ${dir.replace(/s$/, '')} record by slug.`,
      sample: `/${dir}/example.json`,
    });
  }
  for (const f of indexFiles || []) {
    rows.push({
      path: `/${f}`,
      returns: f === 'index.json' ? 'Compact list of every slug. Use for autocomplete.' : `Bulk data: ${f}.`,
      sample: `/${f}`,
    });
  }
  return rows;
}

const rows = endpoints && endpoints.length ? endpoints : defaultEndpoints();
const sampleJson = JSON.stringify(sampleResponse, null, 2);
const license = licenseBlurb ?? 'Code: MIT. Data: CC BY-SA 4.0 (where derived from Wikipedia / public sources).';
---
<Layout title={`API docs - ${apiTitle}`} path="/docs">
  <section class="mx-auto max-w-5xl px-6 pt-16 pb-8">
    <p class="font-mono text-xs uppercase tracking-wider" style="color:var(--color-primary-700)">Reference</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight">API documentation</h1>
    <p class="mt-3 max-w-2xl text-zinc-600 dark:text-zinc-400">All endpoints are static JSON files. No authentication, no rate limiting, no SDK required. Fetch them with anything that speaks HTTP.</p>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Endpoints</h2>
    <div class="mt-4 overflow-x-auto rounded-lg border border-zinc-200 dark:border-zinc-800">
      <table class="w-full text-sm">
        <thead class="bg-zinc-50 text-left dark:bg-zinc-900/50">
          <tr>
            <th class="px-4 py-3 font-medium">Path</th>
            <th class="px-4 py-3 font-medium">Returns</th>
            <th class="px-4 py-3 font-medium">Sample</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-200 dark:divide-zinc-800">
          {rows.map((e) => (
            <tr>
              <td class="px-4 py-3 font-mono text-xs" style="color:var(--color-primary-700)">{e.path}</td>
              <td class="px-4 py-3 text-zinc-700 dark:text-zinc-300">{e.returns}</td>
              <td class="px-4 py-3"><a href={e.sample} class="font-mono text-xs text-zinc-600 underline decoration-zinc-400 underline-offset-4 dark:text-zinc-400" target="_blank" rel="noopener noreferrer">{e.sample}</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-3 text-xs text-zinc-500 dark:text-zinc-500">Base URL: <code class="font-mono text-zinc-700 dark:text-zinc-300">https://{siteHost}</code> &middot; also at <code class="font-mono text-zinc-700 dark:text-zinc-300">{jsdelivrBase}</code></p>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Sample record</h2>
    <pre class="mt-3 overflow-x-auto rounded-md border border-zinc-200 bg-zinc-50 p-4 text-xs dark:border-zinc-800 dark:bg-zinc-900"><code class="font-mono text-zinc-800 dark:text-zinc-200">{sampleJson}</code></pre>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Errors</h2>
    <p class="mt-3 text-zinc-700 dark:text-zinc-300">The only possible error is <code class="font-mono" style="color:var(--color-primary-700)">404</code> &mdash; unknown slug. There is no authentication, no rate limit, and no quota, so 401/403/429 cannot occur. CORS is wide open on both origins.</p>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-8">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">License</h2>
    <p class="mt-3 text-zinc-700 dark:text-zinc-300">{license}</p>
  </section>
</Layout>
